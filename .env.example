# ========================================
# EVOLUTION API
# ========================================
# Chave de autenticação global da Evolution API
AUTHENTICATION_API_KEY=your-strong-random-key-here

# URL pública do servidor (para webhooks)
SERVER_URL=https://api.seudominio.com

# ========================================
# N8N - Workflow Automation
# ========================================
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me

N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.seudominio.com
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# ========================================
# GLPI - Help Desk
# ========================================
GLPI_URL=http://IP_OU_DOMINIO_DO_GLPI

# Gerado em: GLPI > Configurar > Geral > API
# NUNCA commite os valores reais — adicione manualmente no servidor
# GLPI_APP_TOKEN=
# GLPI_USER_TOKEN=

# ========================================
# OLLAMA - IA Local
# ========================================
OLLAMA_URL=http://IP_DO_SERVIDOR_OLLAMA:11434
OLLAMA_MODEL=glpi-assistant:latest
# Tempo máximo de resposta em ms (modelos 8B precisam de 45000+)
OLLAMA_TIMEOUT=60000

# ========================================
# NOME DA INSTÂNCIA WHATSAPP
# ========================================
EVOLUTION_INSTANCE=nome-da-instancia

# ========================================
# BANCO DE DADOS - PostgreSQL (N8N)
# ========================================
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=change-me

# ========================================
# BANCO DE DADOS - MySQL/MariaDB (GLPI)
# ========================================
# Usuário com permissão apenas de leitura para o bot
# GLPI_DB_HOST=IP_DO_GLPI
# GLPI_DB_NAME=glpidb
# GLPI_DB_USER=bot_readonly
# GLPI_DB_PASSWORD=
